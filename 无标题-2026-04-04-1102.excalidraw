      "text": "{\n  \"mcpServers\": {\n    \"Linear\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"-y\",\n        \"mcp-remote\",\n        \"https://mcp.linear.app/mcp\"\n      ]\n    },\n    \"context7\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"-y\",\n        \"@upstash/context7-mcp\",\n        \"--api-key\",\n        \"ctx7sk-56619670-3786-431\"\n      ]\n    },\n    \"docs-langchain\": {\n      \"url\": \"https://docs.langchain.com/mcp\"\n    }\n  }\n}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
