    {
      "id": "Q8tUJptS96tT_QORjLo3N",
      "type": "text",
      "x": 2262.47619047619,
      "y": 2683.571428571429,
      "width": 432.7359619140625,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
